\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{authaffil}[2026/06/09 v1.3 First-appearance affiliation numbering]

\RequirePackage{expl3}
\RequirePackage{xparse}
\RequirePackage{orcidlink}   % \orcidlink for the ORCID argument of \AddAuthor

% ---- option: per-author sorting of the affiliation numbers ---------------
\ExplSyntaxOn
\bool_new:N \g_aa_sort_bool
\bool_gset_true:N \g_aa_sort_bool
\ExplSyntaxOff

\DeclareOption{nosort}{\ExplSyntaxOn\bool_gset_false:N \g_aa_sort_bool\ExplSyntaxOff}
\DeclareOption{sort}{\ExplSyntaxOn\bool_gset_true:N \g_aa_sort_bool\ExplSyntaxOff}
\ProcessOptions\relax

\ExplSyntaxOn

% ---- storage -------------------------------------------------------------
\prop_new:N \g_aa_body_prop      % code -> affiliation address text
\prop_new:N \g_aa_num_prop       % code -> assigned number
\seq_new:N  \g_aa_order_seq      % codes, in order of first appearance
\int_new:N  \g_aa_count_int      % running affiliation counter
\seq_new:N  \g_aa_authors_seq    % rendered author entries
\seq_new:N  \g_aa_notes_seq      % affiliation note entries

\msg_new:nnn { authaffil } { unknown-code }
  { Affiliation~code~'#1'~is~cited~by~an~author~but~was~never~defined~with~
    \token_to_str:N \DefineAffiliation .~No~address~will~be~printed~for~it. }

\msg_new:nnn { authaffil } { unused-affil }
  { Affiliation~code~'#1'~was~defined~but~never~cited~by~any~author;~
    it~will~not~appear~in~the~printed~list. }

% ---- \DefineAffiliation{CODE}{body} --------------------------------------
\NewDocumentCommand \DefineAffiliation { m m }
  {
    \prop_gput:Nnn \g_aa_body_prop {#1} {#2}
  }

% ---- internal: assign a number to a code the first time it is seen --------
\cs_new_protected:Npn \aa_ensure_num:n #1
  {
    \prop_if_in:NnF \g_aa_num_prop {#1}
      {
        \prop_if_in:NnF \g_aa_body_prop {#1}
          { \msg_warning:nnn { authaffil } { unknown-code } {#1} }

        \int_gincr:N \g_aa_count_int
        \prop_gput:Nnx \g_aa_num_prop {#1} { \int_use:N \g_aa_count_int }
        \seq_gput_right:Nn \g_aa_order_seq {#1}
      }
  }

% ---- internal: build the superscript token list for one author ------------
\seq_new:N \l_aa_nums_seq
\tl_new:N  \l_aa_super_tl

\cs_new_protected:Npn \aa_build_super:nn #1#2
  {
    \seq_clear:N \l_aa_nums_seq

    \clist_map_inline:nn {#1}
      {
        \tl_if_blank:nF {##1}
          {
            \aa_ensure_num:n {##1}
            \seq_put_right:Nx \l_aa_nums_seq
              { \prop_item:Nn \g_aa_num_prop {##1} }
          }
      }

    \bool_if:NT \g_aa_sort_bool
      {
        \seq_sort:Nn \l_aa_nums_seq
          {
            \int_compare:nNnTF {##1} > {##2}
              { \sort_return_swapped: }
              { \sort_return_same: }
          }
      }

    \tl_set:Nx \l_aa_super_tl { \seq_use:Nn \l_aa_nums_seq { , } }

    \tl_if_blank:nF {#2}
      {
        \tl_if_empty:NF \l_aa_super_tl
          { \tl_put_right:Nn \l_aa_super_tl { , } }
        \tl_put_right:Nn \l_aa_super_tl {#2}
      }
  }

% ---- \AddAuthor[symbols][orcid]{Name}{codes} -----------------------------
% #1 = footnote symbols
% #2 = ORCID iD
% #3 = name
% #4 = affiliation codes
\tl_new:N \l_aa_orcid_tl

\NewDocumentCommand \AddAuthor { O{} O{} m m }
  {
    \aa_build_super:nn {#4} {#1}

    \tl_clear:N \l_aa_orcid_tl
    \tl_if_blank:nF {#2}
      {
        \tl_set:Nn \l_aa_orcid_tl
          { \nobreakspace \orcidlink {#2} }
      }

    \seq_gput_right:Nx \g_aa_authors_seq
      {
        \exp_not:n {#3}
        $^{ \exp_not:V \l_aa_super_tl }$
        \exp_not:V \l_aa_orcid_tl
      }
  }

% ---- affiliation notes ----------------------------------------------------
% \AddAffilNote{symbol}{text}
% If symbol is blank, prints plain text without an empty superscript.
\NewDocumentCommand \AddAffilNote { m m }
  {
    \seq_gput_right:Nn \g_aa_notes_seq
      { \aa_note_item:nn {#1} {#2} }
  }

% \AddAffilNoteSpace[amount]
% Adds vertical space before the next affiliation note.
% Default: 1mm.
\NewDocumentCommand \AddAffilNoteSpace { O{1mm} }
  {
    \seq_gput_right:Nn \g_aa_notes_seq
      { \aa_note_space:n {#1} }
  }

\tl_new:N   \l_aa_note_sep_tl
\bool_new:N \l_aa_note_seen_bool

\cs_new_protected:Npn \aa_note_item:nn #1#2
  {
    \tl_use:N \l_aa_note_sep_tl

    \tl_if_blank:nTF {#1}
      { #2 }
      { $^{#1}$#2 }

    \bool_set_true:N \l_aa_note_seen_bool
    \tl_set:Nn \l_aa_note_sep_tl { \\ }
  }

\cs_new_protected:Npn \aa_note_space:n #1
  {
    \bool_if:NT \l_aa_note_seen_bool
      {
        \tl_set:Nn \l_aa_note_sep_tl { \\[#1] }
      }
  }

% ---- printing ------------------------------------------------------------
\NewDocumentCommand \PrintAuthors { }
  {
    \seq_use:Nn \g_aa_authors_seq { ,~ }
  }

\bool_new:N \l_aa_first_bool

% \\ is used as a separator, not a terminator, so no trailing \\ is emitted.
\NewDocumentCommand \PrintAffiliations { }
  {
    \footnotesize
    \bool_set_true:N \l_aa_first_bool

    \seq_map_inline:Nn \g_aa_order_seq
      {
        \bool_if:NTF \l_aa_first_bool
          { \bool_set_false:N \l_aa_first_bool }
          { \\ }

        $^{\prop_item:Nn \g_aa_num_prop {##1}}$
        \prop_item:Nn \g_aa_body_prop {##1}
      }
  }

\NewDocumentCommand \PrintAffilNotes { }
  {
    \footnotesize
    \tl_clear:N \l_aa_note_sep_tl
    \bool_set_false:N \l_aa_note_seen_bool

    \seq_map_inline:Nn \g_aa_notes_seq
      {
        ##1
      }
  }

% ---- diagnostics: warn about defined-but-never-cited affiliations ---------
\cs_new_protected:Npn \aa_check_unused:
  {
    \prop_map_inline:Nn \g_aa_body_prop
      {
        \prop_if_in:NnF \g_aa_num_prop {##1}
          { \msg_warning:nnn { authaffil } { unused-affil } {##1} }
      }
  }

\AtEndDocument{ \aa_check_unused: }

\ExplSyntaxOff
\endinput
